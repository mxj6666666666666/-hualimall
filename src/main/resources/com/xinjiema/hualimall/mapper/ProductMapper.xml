<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xinjiema.hualimall.mapper.ProductMapper">
    <!-- 分页查询商品列表 -->
    <select id="selectProductPage" resultType="com.xinjiema.hualimall.pojo.Product">
        SELECT *
        FROM product
#         以下是可能需要的查询条件，根据实际需求进行调整：
<!--        <where>-->
<!--            <if>-->

<!--            </if>-->
<!--        </where>-->
        ORDER BY create_time DESC
    </select>

    <!-- 增加商品 -->
    <insert id="insertProduct" parameterType="com.xinjiema.hualimall.pojo.Product">
        INSERT INTO product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="stock != null">stock,</if>
            <if test="price != null">price,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="status != null">status,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="description != null">description,</if>
        </trim>

        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="stock != null">#{stock},</if>
            <if test="price != null">#{price},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="status != null">#{status},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="description != null">#{description},</if>
        </trim>
    </insert>

    <!-- 批量增加商品 -->
    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO product (name, stock, price, category_id, status, image_url, description)
        VALUES
        <foreach collection="products" item="product" separator=",">
            (#{product.name}, #{product.stock}, #{product.price}, #{product.categoryId}, #{product.status}, #{product.imageUrl}, #{product.description})
        </foreach>
    </insert>

    <!-- 修改商品 -->
    <update id="updateProduct" parameterType="com.xinjiema.hualimall.pojo.Product">
        UPDATE product
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="price != null">price = #{price},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!--批量修改商品-->
    <update id="updateBatch" >
        <foreach collection="products" item="product" separator=";">
            UPDATE product
            <set>
                <!--suppress XmlUnresolvedReference -->
                <if test="product.name != null">name = #{product.name},</if>
                <!--suppress XmlUnresolvedReference -->
                <if test="product.stock != null">stock = #{product.stock},</if>
                <!--suppress XmlUnresolvedReference -->
                <if test="product.price != null">price = #{product.price},</if>
                <!--suppress XmlUnresolvedReference -->
                <if test="product.categoryId != null">category_id = #{product.categoryId},</if>
                <!--suppress XmlUnresolvedReference -->
                <if test="product.status != null">status = #{product.status},</if>
                <!--suppress XmlUnresolvedReference -->
                <if test="product.imageUrl != null">image_url = #{product.imageUrl},</if>
                <!--suppress XmlUnresolvedReference -->
                <if test="product.description != null">description = #{product.description},</if>
            </set>
            WHERE id = #{product.id}
        </foreach>
    </update>

    <!-- 删除商品 -->
    <delete id="deleteProduct">
        DELETE FROM product
        WHERE id = #{id}
    </delete>

    <!-- 批量删除商品 -->
    <delete id="deleteBatch">
        DELETE FROM product
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>