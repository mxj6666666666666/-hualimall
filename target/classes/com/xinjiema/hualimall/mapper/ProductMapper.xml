<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xinjiema.hualimall.mapper.ProductMapper">
    <!-- 分页查询商品列表 -->
    <select id="selectProductPage" resultType="com.xinjiema.hualimall.pojo.Product">
        SELECT *
        FROM product
#         以下是可能需要的查询条件，根据实际需求进行调整：
<!--        <where>-->
<!--            <if>-->

<!--            </if>-->
<!--        </where>-->
        ORDER BY create_time DESC
    </select>

    <!-- 增加商品 -->
    <insert id="insertProduct" parameterType="com.xinjiema.hualimall.pojo.Product">
        INSERT INTO product
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">name,</if>
            <if test="stock != null">stock,</if>
            <if test="price != null">price,</if>
            <if test="categoryId != null">category_id,</if>
            <if test="status != null">status,</if>
            <if test="imageUrl != null">image_url,</if>
            <if test="description != null">description,</if>
        </trim>

        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null">#{name},</if>
            <if test="stock != null">#{stock},</if>
            <if test="price != null">#{price},</if>
            <if test="categoryId != null">#{categoryId},</if>
            <if test="status != null">#{status},</if>
            <if test="imageUrl != null">#{imageUrl},</if>
            <if test="description != null">#{description},</if>
        </trim>
    </insert>

</mapper>